@if (Profile != null)
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddEducation" Class="mb-4"
               StartIcon="@Icons.Material.Filled.Add">@Localizer["AddEducation"]</MudButton>

    <MudStack Spacing="4">
        @foreach (var edu in Profile.Educations)
        {
            <MudCard Class="pa-3" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="edu.InstitutionName" Label="@Localizer["Institution"]"
                                      Variant="Variant.Text" Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.School" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="edu.Degree" Label="@Localizer["Degree"]" Variant="Variant.Text"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.WorkspacePremium" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="edu.StartDate" Label="@Localizer["StartDate"]" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="edu.EndDate" Label="@Localizer["EndDate"]" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                   Class="ml-auto d-flex align-items-end" Size="Size.Small"
                                   OnClick="@(() => RemoveEducation(edu))" StartIcon="@Icons.Material.Filled.Delete">
                            @Localizer["Remove"]
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" Class="pt-2">
                        <MudTextField @bind-Value="edu.Description" Label="@Localizer["Description"]" Lines="3"
                                      Sizing="InputSizing.Auto" Variant="Variant.Outlined" Clearable="true"
                                      HelperText="@Localizer["EducationDescriptionHelper"]" />
                    </MudItem>
                </MudGrid>
            </MudCard>
        }
    </MudStack>
}
