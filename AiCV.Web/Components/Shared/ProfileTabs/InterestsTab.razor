@if (Profile != null)
{
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_newInterest"
                          Class="flex-grow-1"
                          Label="@Localizer["AddInterest"]"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentColor="Color.Primary"
                          AdornmentIcon="@Icons.Material.Outlined.Add"
                          OnAdornmentClick="AddInterest"
                          Immediate="true" />
        </MudStack>

        <MudChipSet T="string">
            @foreach (var interest in Profile.Interests.Where(i => !string.IsNullOrWhiteSpace(i.Name)).ToList())
            {
                var interestName = interest.Name?.Trim() ?? string.Empty;
                <MudChip T="string" Value="@interestName" Text="@interestName" Color="Color.Primary"
                         OnClose="@((MudChip<string> chip) => RemoveInterest(interest))" />
            }
        </MudChipSet>
    </MudStack>
}
