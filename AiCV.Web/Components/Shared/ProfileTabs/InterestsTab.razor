@if (Profile != null)
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddInterest" Class="mb-4"
               StartIcon="@Icons.Material.Filled.Add">@Localizer["AddInterest"]</MudButton>

    <MudGrid>
        @foreach (var interest in Profile.Interests)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="pa-3" Elevation="2">
                    <MudStack Spacing="2">
                        <MudTextField @bind-Value="interest.Name" Label="@Localizer["Interests"]"
                                      Variant="Variant.Text" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                   OnClick="@(() => RemoveInterest(interest))" StartIcon="@Icons.Material.Filled.Delete">
                            @Localizer["Remove"]
                        </MudButton>
                    </MudStack>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
