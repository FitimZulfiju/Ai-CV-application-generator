@if (Profile != null)
{
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center">
            @{
                var proficiencyLabel = $"{Localizer["Proficiency"]} ({Localizer["LanguageProficiencyHelper"]})";
            }
            <MudTextField @bind-Value="_newLanguageName"
                          Class="flex-grow-1"
                          Label="@Localizer["Language"]"
                          Variant="Variant.Outlined"
                          Immediate="true" />
            <MudTextField @bind-Value="_newLanguageProficiency"
                          Class="flex-grow-1"
                          Label="@proficiencyLabel"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.End"
                          AdornmentColor="Color.Primary"
                          AdornmentIcon="@Icons.Material.Filled.Add"
                          OnAdornmentClick="AddLanguage" />
        </MudStack>

        <MudChipSet T="string">
            @foreach (var lang in Profile.Languages.Where(l => !string.IsNullOrWhiteSpace(l.Name)).ToList())
            {
                var languageName = lang.Name?.Trim() ?? string.Empty;
                var proficiency = lang.Proficiency?.Trim() ?? string.Empty;
                var chipText = string.IsNullOrWhiteSpace(proficiency)
                    ? languageName
                    : $"{languageName} {proficiency}";

                <MudChip T="string" Value="@chipText" Color="Color.Primary"
                         OnClose="@((MudChip<string> chip) => RemoveLanguage(lang))">
                    <FormattedText Text="@languageName" />
                    @if (!string.IsNullOrWhiteSpace(proficiency))
                    {
                        <span>&nbsp;</span>
                        <FormattedText Text="@proficiency" />
                    }
                </MudChip>
            }
        </MudChipSet>
    </MudStack>
}
