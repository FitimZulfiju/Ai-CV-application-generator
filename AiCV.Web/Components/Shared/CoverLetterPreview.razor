@if (Template == CvTemplate.Professional)
{
    <ProfessionalCoverLetter Profile="Profile" LetterContent="@LetterContent" />
}
else if (Template == CvTemplate.Modern)
{
    <ModernCoverLetter Profile="Profile" LetterContent="@LetterContent" />
}
else if (Template == CvTemplate.Minimalist)
{
    <MinimalistCoverLetter Profile="Profile" LetterContent="@LetterContent" />
}
