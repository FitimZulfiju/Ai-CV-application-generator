@attribute [Microsoft.AspNetCore.Components.Route(NavUri.ProfilePage)]
@attribute [Authorize]

<PageTitle>@Localizer["MasterCvProfile"]</PageTitle>

@if (_isLoading)
{
}
else if (_profile == null)
{
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  Class="pb-4 d-print-none stack-on-mobile" Style="gap: 16px;">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
                <MudText Typo="Typo.h5">@Localizer["MasterCvProfile"]</MudText>
                <MudTooltip Text="@Localizer["FormattingHelp"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => _showFormattingHelp = true)" />
                </MudTooltip>
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="justify-center">
                @if (_activeTabIndex != 7)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Medium" OnClick="SaveProfile"
                               Disabled="_isSaving" Style="white-space: nowrap;"
                               StartIcon="@(_isSaving ? null : Icons.Material.Filled.Save)">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>@Localizer["Saving"]</span>
                        }
                        else
                        {
                            @Localizer["Save"]
                        }
                    </MudButton>
                }
                @if (_activeTabIndex == 7)
                {
                    <MudSelect T="CvTemplate" @bind-Value="_selectedTemplate" Label="@Localizer["Template"]" Class="pa-0 ma-0 mr-2" Style="width:150px;"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="CvTemplate.Professional">@Localizer["Professional"]</MudSelectItem>
                        <MudSelectItem Value="CvTemplate.Modern">@Localizer["Modern"]</MudSelectItem>
                        <MudSelectItem Value="CvTemplate.Minimalist">@Localizer["Minimalist"]</MudSelectItem>
                    </MudSelect>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium" OnClick="PrintProfile"
                               Disabled="_isPrinting" Style="white-space: nowrap;"
                               StartIcon="@(_isPrinting ? null : Icons.Material.Filled.Print)">
                        @if (_isPrinting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>@Localizer["Printing"]</span>
                        }
                        else
                        {
                            @Localizer["PrintCv"]
                        }
                    </MudButton>
                }
            </MudStack>
        </MudStack>
        <MudTabs Elevation="1" Rounded="true" @bind-ActivePanelIndex="_activeTabIndex">
            
            <MudDivider DividerType="DividerType.Middle" Class="my-3" />

            @* Tab Personal Details *@
            <MudTabPanel Text="@Localizer["PersonalDetails"]" Icon="@Icons.Material.Filled.Person">
                <PersonalDetailsTab Profile="_profile" OnFilesChanged="UploadFiles" OnDeletePicture="DeleteProfilePicture" />
            </MudTabPanel>

            @* Tab Experience *@
            <MudTabPanel Text="@Localizer["Experience"]" Icon="@Icons.Material.Filled.WorkHistory">
                <ExperienceTab Profile="_profile" />
            </MudTabPanel>

            @* Tab Education *@
            <MudTabPanel Text="@Localizer["Education"]" Icon="@Icons.Material.Filled.School">
                <EducationTab Profile="_profile" />
            </MudTabPanel>

            @* Tab Skills *@
            <MudTabPanel Text="@Localizer["Skills"]" Icon="@Icons.Material.Filled.Build">
                <SkillsTab Profile="_profile" SkillCategories="_skillCategories" OnSkillsUpdated="UpdateProfileSkills" />
            </MudTabPanel>

            @* Tab Projects *@
            <MudTabPanel Text="@Localizer["Projects"]" Icon="@Icons.Material.Filled.Code">
                <ProjectsTab Profile="_profile" />
            </MudTabPanel>

            @* Tab Languages *@
            <MudTabPanel Text="@Localizer["Languages"]" Icon="@Icons.Material.Filled.Language">
                <LanguagesTab Profile="_profile" />
            </MudTabPanel>

            @* Tab Interests *@
            <MudTabPanel Text="@Localizer["Interests"]" Icon="@Icons.Material.Filled.Interests">
                <InterestsTab Profile="_profile" />
            </MudTabPanel>

            @* Tab CV Preview *@
            <MudTabPanel Text="@Localizer["CvPreview"]" Icon="@Icons.Material.Filled.Preview" Style="background-color:cornflowerblue;color:whitesmoke; border-radius:0.5rem;">
                <AiCV.Web.Components.Shared.CvPreview Profile="@_profile" Template="@_selectedTemplate" />
            </MudTabPanel>
        </MudTabs>
    </MudContainer>
}

<AiCV.Web.Components.Shared.PrintPreviewModal @ref="_printPreviewModal" />

<MudDialog @bind-Visible="_showFormattingHelp"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.FormatColorText" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@Localizer["FormattingHelpTitle"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Dense="true">
                @Localizer["FormattingHelpDescription"]
            </MudAlert>

            <MudText Typo="Typo.subtitle1"><strong>@Localizer["LineBreaks"]</strong></MudText>
            <MudText Typo="Typo.body2">@Localizer["LineBreaksDescription"]</MudText>
            <MudPaper Class="pa-2 mud-theme-secondary" Elevation="0">
                <code>Line 1<br />Line 2<br />Line 3</code>
            </MudPaper>

            <MudDivider />

            <MudText Typo="Typo.subtitle1">
                <strong>@Localizer["BulletPoints"] (Experience &amp; Projects)</strong>
            </MudText>
            <MudText Typo="Typo.body2">
                @Localizer["BulletPointsDescription"]
            </MudText>
            <MudPaper Class="pa-2 mud-theme-secondary" Elevation="0">
                <code>- Built REST APIs using ASP.NET Core<br />- Implemented CI/CD pipelines<br />* Reduced deployment time by 40%</code>
            </MudPaper>

            <MudDivider />

            <MudText Typo="Typo.subtitle1"><strong>@Localizer["HtmlTags"]</strong></MudText>
            <MudText Typo="Typo.body2">@Localizer["HtmlTagsDescription"]</MudText>
            <MudPaper Class="pa-2 mud-theme-secondary" Elevation="0">
                <code>&lt;strong&gt;Bold text&lt;/strong&gt;<br />&lt;em&gt;Italic text&lt;/em&gt;</code>
            </MudPaper>

            <MudDivider />

            <MudText Typo="Typo.subtitle1"><strong>@Localizer["SupportedFields"]</strong></MudText>
            <MudAlert Severity="Severity.Success" Dense="true" Icon="@Icons.Material.Filled.DoneAll">
                @Localizer["AllTextFieldsSupportFormatting"]
            </MudAlert>

            <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                <thead>
                    <MudTr>
                        <MudTh>@Localizer["FormattingType"]</MudTh>
                        <MudTh>@Localizer["Syntax"]</MudTh>
                        <MudTh>@Localizer["SupportedIn"]</MudTh>
                    </MudTr>
                </thead>
                <tbody>
                    <MudTr>
                        <MudTd><strong>@Localizer["BoldMarkdown"]</strong></MudTd>
                        <MudTd><code>**text**</code></MudTd>
                        <MudTd>@Localizer["AllFields"]</MudTd>
                    </MudTr>
                    <MudTr>
                        <MudTd><strong>@Localizer["HtmlTags"]</strong></MudTd>
                        <MudTd><code>&lt;strong&gt;, &lt;em&gt;, &lt;u&gt;</code></MudTd>
                        <MudTd>@Localizer["AllFields"]</MudTd>
                    </MudTr>
                    <MudTr>
                        <MudTd><strong>@Localizer["LineBreaks"]</strong></MudTd>
                        <MudTd>@Localizer["EnterKey"]</MudTd>
                        <MudTd>@Localizer["AllFields"]</MudTd>
                    </MudTr>
                    <MudTr>
                        <MudTd><strong>@Localizer["BulletPoints"]</strong></MudTd>
                        <MudTd><code>- @Localizer["or"] *</code></MudTd>
                        <MudTd>@Localizer["DescriptionsOnly"]</MudTd>
                    </MudTr>
                </tbody>
            </MudSimpleTable>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(() => _showFormattingHelp = false)">@Localizer["GotIt"]</MudButton>
    </DialogActions>
</MudDialog>
