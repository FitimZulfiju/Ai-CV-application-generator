@inherits LayoutComponentBase
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudScrollToTop Selector=".main-content" TopOffset="400" ScrollBehavior="ScrollBehavior.Smooth">
    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
</MudScrollToTop>

<MudLayout Class="main-layout-shell"
           Style="background-image: url('/mbg.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; min-height: 100vh;">
    <MudAppBar Elevation="3" Dense="true" Color="Color.Transparent">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" Class="appbar-menu-button"
                       OnClick="@((e) => DrawerToggle())" />
        <MudImage Src="/logoSvg.svg" Alt="AI Web CV Logo" Style="cursor: pointer;" Class="responsive-logo"
                  @onclick="NavigateToHome" />
        <MudText Typo="Typo.h6" Class="responsive-app-title">@Localizer["AiCvApplications"]</MudText>
        <div class="appbar-breadcrumb-center">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="appbar-breadcrumb-chip">
                <MudBreadcrumbs Items="_breadcrumbs" />
            </MudChip>
        </div>
        <MudSpacer />
        <LanguageSwitcher />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"
                       Href="https://github.com/fitimzulfiju/Ai-CV-application-generator" Target="_blank" />
    </MudAppBar>
    @if (LoadingService.IsVisible)
    {
        <AiCV.Web.Components.Shared.LoadingIndicator Color="Color.Info" Size="Size.Large" Value="@LoadingService.Percentage"
                                                     Indeterminate="@(LoadingService.Percentage <= 0)" Class="top-loading-indicator">
            <MudText Typo="Typo.subtitle1" Color="Color.Dark">
                <b>
                    @LoadingService.Percentage
                    %
                </b>
            </MudText>
        </AiCV.Web.Components.Shared.LoadingIndicator>
    }
    @if (_isMobile)
    {
        <MudDrawer @key="@("mobile-drawer")" @bind-Open="_mobileDrawerOpen" Variant="DrawerVariant.Temporary"
                   OverlayAutoClose="true" Elevation="4" Class="responsive-drawer">
            <NavMenu ShowLoggedInAs="true" />
        </MudDrawer>
    }
    else
    {
        <MudDrawer @key="@("desktop-drawer")" @bind-Open="_desktopDrawerOpen" Variant="DrawerVariant.Mini"
                   Breakpoint="Breakpoint.Always" ClipMode="DrawerClipMode.Always" Elevation="4"
                   Class="responsive-drawer">
            <NavMenu ShowLoggedInAs="_desktopDrawerOpen" />
        </MudDrawer>
    }
    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
    <AiCV.Web.Components.Shared.UpdateBanner />
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    @Localizer["UnhandledError"]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">X</span>
</div>
